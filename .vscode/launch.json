  "version": "0.2.0",
  "configurations": [
        {
            "name": "Debug Host App (Mac)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "Flash to Pico",
      "type": "node-terminal",
      "request": "launch",
      "command": "(picotool reboot -f -u 2>/dev/null || echo 'Put Pico in BOOTSEL mode...') && sleep 2 && picotool load -x ${workspaceFolder}/build/${config:cmake.buildDirectoryRel}/RP2350-FreeRTOS-Template-Multiplatform.uf2 && echo '✅ Flashed successfully!'",
      "cwd": "${workspaceFolder}"
    },
    
  ]
}
