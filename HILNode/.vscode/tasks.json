{
    "version": "2.0.0",
    "tasks": [
        // ── Step 1: Build ─────────────────────────────────────────────
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --config Debug -j4",
            "group": {
                "kind": "build"
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },

        // ── Step 2: Copy .uf2 to Rockchip ─────────────────────────────
        {
            "label": "SSH: Copy .uf2 to Rockchip",
            "type": "shell",
            "dependsOn": "CMake: Build",
            "group": {
                "kind": "build"
            },
            "command": "scp ${config:phoenix.build.uf2} ${config:phoenix.ssh.user}@${config:phoenix.ssh.host}:${config:phoenix.ssh.remotePath}",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },

        // ── Step 3: Reboot Pico into BOOTSEL, then flash ───────────────
        {
            "label": "SSH: Flash Pico",
            "type": "shell",
            "dependsOn": "SSH: Copy .uf2 to Rockchip",
            "group": {
                "kind": "build"
            },
            "command": "ssh -t ${config:phoenix.ssh.user}@${config:phoenix.ssh.host} \"sudo fuser -k ${config:phoenix.ssh.device} 2>/dev/null; echo 'Rebooting to Bootloader...'; sudo picotool reboot --bus ${config:phoenix.ssh.bus} -f -u; echo 'Waiting for USB...'; sleep 3; echo 'Flashing...'; sudo picotool load --bus ${config:phoenix.ssh.bus} --ignore-partitions -x ${config:phoenix.ssh.remotePath} && echo FLASH_OK\"",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },

        // ── Top-level: Run Project (SSH) ───────────────────────────────
        // This is the one you click. It chains all three steps above.
        {
            "label": "Run Project (SSH)",
            "dependsOn": "SSH: Flash Pico",
            "group": {
                "kind": "build"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },

        // ── Bonus: Open Serial Monitor over SSH ───────────────────────
        // Assumes the Pico mounts as the configured device on the Rockchip.
        // Uses 'minicom' — install with: sudo apt install minicom
        {
            "label": "SSH: Serial Monitor",
            "type": "shell",
            "group": {
                "kind": "build"
            },
            "command": "ssh -t ${config:phoenix.ssh.user}@${config:phoenix.ssh.host} \"sudo fuser -k ${config:phoenix.ssh.device} 2>/dev/null; sudo rm -f /var/lock/LCK..*; sleep 1; sudo minicom -D ${config:phoenix.ssh.device} -b 115200\"",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            }
        },

        // ── Top-level: Flash and Monitor (SSH) ────────────────────────
        {
            "label": "Run Project & Monitor (SSH)",
            "dependsOn": [
                "Run Project (SSH)",
                "SSH: Serial Monitor"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Compile Project",
            "type": "process",
            "isBuildCommand": true,
            "command": "${userHome}/.pico-sdk/ninja/v1.12.1/ninja",
            "args": ["-C", "${workspaceFolder}/build"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc",
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/ninja/v1.12.1/ninja.exe"
            }
        },
        {
            "label": "Run Project",
            "type": "process",
            "command": "${env:HOME}/.pico-sdk/picotool/2.2.0-a4/picotool/picotool",
            "args": [
                "load",
                "${command:raspberry-pi-pico.launchTargetPath}",
                "-fx"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/picotool/2.2.0-a4/picotool/picotool.exe"
            }
        },
        {
            "label": "Flash",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            "args": [
                "-s",
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f",
                "interface/cmsis-dap.cfg",
                "-f",
                "target/${command:raspberry-pi-pico.getTarget}.cfg",
                "-c",
                "adapter speed 5000; program \"${command:raspberry-pi-pico.launchTargetPath}\" verify reset exit"
            ],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            }
        },
        {
            "label": "Rescue Reset",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            "args": [
                "-s",
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f",
                "interface/cmsis-dap.cfg",
                "-f",
                "target/${command:raspberry-pi-pico.getChip}-rescue.cfg",
                "-c",
                "adapter speed 5000; reset halt; exit"
            ],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            }
        },
        {
            "label": "RISC-V Reset (RP2350)",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            "args": [
                "-s",
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-c",
                "set USE_CORE { rv0 rv1 cm0 cm1 }",
                "-f",
                "interface/cmsis-dap.cfg",
                "-f",
                "target/rp2350.cfg",
                "-c",
                "adapter speed 5000; init;",
                "-c",
                "write_memory 0x40120158 8 { 0x3 }; echo [format \"Info : ARCHSEL 0x%02x\" [read_memory 0x40120158 8 1]];",
                "-c",
                "reset halt; targets rp2350.rv0; echo [format \"Info : ARCHSEL_STATUS 0x%02x\" [read_memory 0x4012015C 8 1]]; exit"
            ],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            }
        }
    ]
}
