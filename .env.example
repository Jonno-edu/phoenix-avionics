# ============================================================================
# Phoenix Avionics - Environment Configuration
# Copy this file to .env and customize for your setup
# ============================================================================

# Rock Pi SSH Configuration
ROCK_PI_HOST=100.115.224.114
ROCK_PI_USER=rock
ROCK_PI_PORT=22

# Pico Board Configuration
# Options: pico2_w, pico2, pico_w, pico
PICO_BOARD=pico2_w

# Build Configuration
BUILD_TYPE=Release

# Number of parallel build jobs (default: auto-detect)
# JOBS=4
